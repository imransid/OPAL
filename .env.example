# Admin panel access. Copy to .env and set your own values. Never commit .env.

# Public site URL (SEO: canonical, sitemap, Open Graph). No trailing slash.
# Next.js: set NEXT_PUBLIC_SITE_URL (preferred). Legacy: PUBLIC_SITE_URL still read on server where supported.
NEXT_PUBLIC_SITE_URL=https://opal.example.com
PUBLIC_SITE_URL=https://opal.example.com

# Optional: Google Search Console HTML tag verification (meta content value only)
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Password for normal admin login
PUBLIC_ADMIN_PASSWORD=your-secure-password

# Email for "forgot password" — only this email can request a login code (default: emailofimran1992@gmail.com)
PUBLIC_ADMIN_EMAIL=emailofimran1992@gmail.com

# New order alerts to your inbox (Gmail app password). Spaces in app password are OK.
EMAIL_USER=
EMAIL_PASS=
# Optional: different inbox than EMAIL_USER (defaults to EMAIL_USER or PUBLIC_ADMIN_EMAIL)
ORDER_NOTIFY_TO=

# Send login code by email (Resend). Get API key at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxx
# Sender address (default: emailofimran1992@gmail.com). For custom domain, use a verified domain in Resend.
RESEND_FROM_EMAIL=OPAL Admin <emailofimran1992@gmail.com>

# Firebase (required for products, categories, seed). From Firebase Console → Project settings.
# Client (browser): use NEXT_PUBLIC_FIREBASE_* — or duplicate values below as PUBLIC_* (server still reads PUBLIC_*).
